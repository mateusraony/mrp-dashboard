# Render static site cache headers
# index.html: nunca cachear — garante que o browser sempre busca a versão mais recente após deploy
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Assets com hash no nome: cachear por 1 ano (imutáveis — o hash muda a cada build)
/assets/*
  Cache-Control: public, max-age=31536000, immutable
